# Public site URL (canonical, OG, sitemap)
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Twitch Helix — https://dev.twitch.tv/console/apps
# Powers the live-status pill and the VODs section.
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# YouTube Data API v3 — https://console.cloud.google.com/apis
# Powers the Latest Videos grid.
YOUTUBE_API_KEY=

# X API v2 bearer token — used ONLY by scripts/sync-tweets.mjs, which
# merges new tweets into data/tweets.json. The site always renders that
# file, so this is not needed to build or run.
# Reading a user timeline requires a PAID X API plan; on the free tier the
# script reports 403 and skips, leaving the JSON untouched.
X_BEARER_TOKEN=
# Optional overrides for the sync script.
# X_USERNAME=Asmongold
# TWEET_LIMIT=16

# Optional RSS/CMS feed for the News section. Falls back to curated entries.
NEWS_FEED_URL=
