# Public site URL (canonical, OG, sitemap)
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Twitch Helix — https://dev.twitch.tv/console/apps
# Powers the live-status pill and the VODs section.
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# YouTube Data API v3 — https://console.cloud.google.com/apis
# Powers the Latest Videos grid.
YOUTUBE_API_KEY=

# No X credentials needed: the Latest Tweets section uses official X embeds,
# which X renders client-side. Change the featured posts by editing
# FEATURED_TWEET_IDS in lib/data.ts.

# Optional RSS/CMS feed for the News section. Falls back to curated entries.
NEWS_FEED_URL=
